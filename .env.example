COMPOSE_PROJECT_NAME=pep

APP_HOST=app.localhost
API_HOST=api.localhost
N8N_HOST=n8n.localhost

FRONTEND_PORT=3000
BACKEND_PORT=3001

APP_PUBLIC_URL=http://app.localhost
NEXT_PUBLIC_API_URL=http://api.localhost
FRONTEND_ORIGIN=http://app.localhost

POSTGRES_DB=pep
POSTGRES_USER=pep
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql://pep:change-me-postgres@postgres:5432/pep?schema=public

BACKEND_APP_SECRET=change-me-backend-secret
# Internal n8n callback to POST /api/v1/applications/:ticketId/result must send this as x-app-secret.

N8N_PROTOCOL=http
N8N_PORT=5678
N8N_EDITOR_BASE_URL=http://n8n.localhost
WEBHOOK_URL=http://n8n.localhost/
N8N_WORKFLOW_WEBHOOK_URL=http://n8n:5678/webhook/generate-cv
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-password
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key
N8N_SECURE_COOKIE=false
N8N_IMPORT_SEED=true
N8N_IMPORT_CREDENTIALS=true
N8N_GOOGLE_DOCS_CREDENTIAL_NAME=Google Docs account
# Use a Google service account for fully automated Google Docs bootstrap in n8n.
N8N_GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep this on a single line and escape newlines as \n.
N8N_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
N8N_GOOGLE_SERVICE_ACCOUNT_IMPERSONATE=false
# Optional. Use when domain-wide delegation is enabled in Google Workspace.
N8N_GOOGLE_SERVICE_ACCOUNT_DELEGATED_EMAIL=
N8N_GOOGLE_GEMINI_CREDENTIAL_NAME=Google Gemini(PaLM) Api account
N8N_GOOGLE_GEMINI_API_HOST=https://generativelanguage.googleapis.com

# Deprecated for automated bootstrap. Keep empty unless you plan to wire Google Docs manually via OAuth2 in the UI.
GOOGLE_DOCS_CLIENT_ID=
GOOGLE_DOCS_CLIENT_SECRET=
GOOGLE_GEMINI_API_KEY=
