generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationTicketStatus {
  processing
  completed
  failed
}

model AppMetadata {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationTicket {
  id                 String                  @id @default(cuid())
  status             ApplicationTicketStatus
  companyName        String
  vacancyDescription String
  lastError          String?
  result             ApplicationTicketResult?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model ApplicationTicketResult {
  ticketId          String            @id
  ticket            ApplicationTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  cvMarkdown        String
  coverLetterMarkdown String
  personalNote      String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}
