{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint src prisma --max-warnings=0",
    "test": "echo 'No tests for @repo/api'",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-express": "^11.1.1",
    "@prisma/client": "^6.10.1",
    "@repo/contracts": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/node": "^24.0.4",
    "prisma": "^6.10.1"
  }
}
