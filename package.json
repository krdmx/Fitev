{
  "name": "pep",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "pnpm --filter @repo/api prisma:generate",
    "build": "turbo run build",
    "start": "docker compose -f docker-compose.yaml up -d --build --remove-orphans",
    "stop": "docker compose -f docker-compose.yaml down --remove-orphans",
    "logs": "docker compose -f docker-compose.yaml logs -f",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@next/eslint-plugin-next": "^15.3.4",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
